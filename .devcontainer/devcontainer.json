{
    "image": "mcr.microsoft.com/devcontainers/base:bookworm",
    "remoteEnv": {
        "OLLAMA_MODEL": "llama3.2:3b",
        "GROQ_API_KEY": "${localEnv:GROQ_API_KEY}"
    },
    "hostRequirements": { "cpus": 4, "memory": "16gb", "storage": "32gb" },
    "features": {
        "ghcr.io/devcontainers/features/github-cli:1": {},
        "ghcr.io/devcontainers/features/python:1": {}
    },
    "customizations": {
        "vscode": {
            "settings": {
                "python.defaultInterpreterPath": "py_env/bin/python",
                "github.copilot.enable": { "*": false },
                "editor.inlineSuggest.enabled": false,
                "workbench.startupEditor": "readme",
                "workbench.editorAssociations": { "*.md": "vscode.markdown.preview.editor" },
                "files.associations": { "*.mmd": "mermaid" },
                "terminal.integrated.defaultProfile.linux": "bash"
            },
            "keybindings": [
                {
                    "key": "ctrl+alt+m",
                    "command": "preview.mermaidChart.preview",
                    "when": "editorTextFocus && resourceExtname == .mmd"
                }
            ],
            "extensions": ["vstirbu.vscode-mermaid-preview"]
        }
    },
    "postCreateCommand": "bash -i scripts/pysetup.sh py_env && bash scripts/startup_ollama.sh",
    "postAttachCommand": "bash scripts/startOllama.sh"
}
