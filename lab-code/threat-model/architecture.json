{
  "system": "OmniTech Customer Support AI Assistant",
  "description": "A customer-facing support assistant that answers questions from internal docs (RAG), can look up account data and open tickets via tools exposed over MCP, and runs an agent loop to decide which tools to call.",
  "components": [
    {"id": "web_ui",      "type": "ui",        "trust_zone": "public",   "handles_pii": false},
    {"id": "chat_llm",    "type": "llm",       "trust_zone": "app",      "handles_pii": true},
    {"id": "rag_kb",      "type": "rag",       "trust_zone": "app",      "handles_pii": false},
    {"id": "doc_store",   "type": "datastore", "trust_zone": "internal", "handles_pii": false},
    {"id": "support_agent","type": "agent",    "trust_zone": "app",      "handles_pii": true},
    {"id": "mcp_gateway", "type": "mcp",       "trust_zone": "app",      "handles_pii": true},
    {"id": "account_tool","type": "tool",      "trust_zone": "internal", "handles_pii": true},
    {"id": "ticket_tool", "type": "tool",      "trust_zone": "internal", "handles_pii": false},
    {"id": "crm_db",      "type": "datastore", "trust_zone": "internal", "handles_pii": true},
    {"id": "ci_pipeline", "type": "deploy",    "trust_zone": "internal", "handles_pii": false}
  ],
  "data_flows": [
    {"from": "web_ui",       "to": "chat_llm",     "data": "user message"},
    {"from": "chat_llm",     "to": "rag_kb",       "data": "retrieval query"},
    {"from": "rag_kb",       "to": "doc_store",    "data": "vector lookup"},
    {"from": "chat_llm",     "to": "support_agent","data": "tool plan"},
    {"from": "support_agent","to": "mcp_gateway",  "data": "tool call"},
    {"from": "mcp_gateway",  "to": "account_tool", "data": "lookup request"},
    {"from": "mcp_gateway",  "to": "ticket_tool",  "data": "create ticket"},
    {"from": "account_tool", "to": "crm_db",       "data": "SQL query"},
    {"from": "ci_pipeline",  "to": "chat_llm",     "data": "model + prompt deploy"}
  ],
  "trust_boundaries": [
    {"name": "Internet edge",      "between": ["public", "app"]},
    {"name": "App-to-data",        "between": ["app", "internal"]}
  ]
}
